{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build mini_sql",
            "type": "shell",
            "command": "/usr/bin/cc",
            "args": [
                "-std=c11",
                "-Wall",
                "-Wextra",
                "-pedantic",
                "-Iinclude",
                "src/main.c",
                "src/parser.c",
                "src/executor.c",
                "src/schema_manager.c",
                "src/storage.c",
                "-o",
                "mini_sql"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
